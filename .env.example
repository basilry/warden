# WARDEN runtime provider.
# mock is offline and requires no credentials.
WARDEN_MODEL_PROVIDER=mock

# Codex CLI provider.
# Recommended auth path: run `codex login` once. WARDEN does not read
# ~/.codex/auth.json directly; the Codex CLI handles OAuth.
#
# To use the Codex provider:
# WARDEN_MODEL_PROVIDER=codex
WARDEN_CODEX_DRY_RUN=1
WARDEN_CODEX_COMMAND=codex
WARDEN_CODEX_SANDBOX=read-only
WARDEN_CODEX_TIMEOUT_MS=120000
# WARDEN_CODEX_MODEL=
#
# Optional API-key login for Codex CLI:
#   set -a; source .env; set +a
#   printenv OPENAI_API_KEY | codex login --with-api-key
# Prefer plain `codex login` for local OAuth use.

# Shared OpenAI API key.
# - Used by `codex login --with-api-key` when you pipe it to Codex CLI.
# - Read directly by WARDEN only for the openai-compatible provider when
#   dry-run is disabled.
OPENAI_API_KEY=

# OpenAI-compatible provider.
# This path is separate from Codex OAuth.
# WARDEN_MODEL_PROVIDER=openai-compatible
WARDEN_OPENAI_DRY_RUN=1
WARDEN_OPENAI_LIVE_OPT_IN=false
WARDEN_OPENAI_ENDPOINT=https://api.openai.com/v1/responses
WARDEN_OPENAI_MODEL=gpt-5.4
WARDEN_OPENAI_API_KEY_ENV=OPENAI_API_KEY

# Runtime server.
WARDEN_PORT=8787

# Optional storage.
WARDEN_STORAGE=memory
WARDEN_STORAGE_DIR=data
