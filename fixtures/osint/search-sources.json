    {
      "id": "gdelt-doc-global",
      "name": "GDELT DOC Article Search",
      "kind": "gdelt-doc",
      "endpoint": "https://api.gdeltproject.org/api/v2/doc/doc",
      "enabled": true,
      "allowedDomains": ["api.gdeltproject.org"],
      "allowedPaths": ["/api/v2/doc/"],
      "querySuffix": "(military OR defense OR defence OR security OR sanction OR supply chain OR missile OR navy OR army OR drone OR semiconductor OR shipping)",
      "reliability": "C3",
      "rateLimitKey": "gdelt-doc-api",
      "cooldownMs": 60000,
      "backoffMultiplier": 2,
      "tags": ["gdelt", "news", "defense", "public-search"]
    },
